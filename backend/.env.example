# MySQL (XAMPP) — ajuste usuario/contraseña según su instalación
DATABASE_URL="mysql://root@localhost:3306/tesis_dashboard"

# JWT — use una clave >= 32 caracteres en producción
JWT_SECRET="cambiar-por-clave-segura-minimo-32-caracteres"
JWT_EXPIRES_IN="8h"
JWT_REFRESH_EXPIRES_IN="7d"

# Servidor API
PORT=4000
NODE_ENV="development"
CORS_ORIGIN="http://localhost:3029"

# Servicio ML (FastAPI)
ML_SERVICE_URL="http://localhost:5000"

# Primer director (npm run db:bootstrap)
ADMIN_EMAIL="director@iep-huancayo.edu.pe"
ADMIN_PASSWORD="Tesis2026!"
ADMIN_NOMBRES="Director"
ADMIN_APELLIDOS="Institucional"

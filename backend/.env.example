# =============================================================================
# Backend — variables de entorno (copiar a backend/.env local; NO subir .env)
# Producción: Railway → Variables del servicio backend
# =============================================================================

# MySQL local (XAMPP)
DATABASE_URL="mysql://root@localhost:3306/tesis_dashboard"

# MySQL Railway — usar la URL del plugin (TCP proxy externo o variable referenciada)
# Ejemplo proxy: mysql://USER:PASS@acela.proxy.rlwy.net:34678/railway
# Dentro de Railway el host interno es mysql.railway.internal:3306
# DATABASE_URL="${{MySQL.MYSQL_URL}}"

JWT_SECRET="cambiar-por-clave-segura-minimo-32-caracteres"
JWT_EXPIRES_IN="8h"

PORT=4000
HOST=0.0.0.0
NODE_ENV=development

# CORS — orígenes separados por coma (producción + local)
# CORS_ORIGIN="https://taller1-frontend.vercel.app,http://localhost:3000,http://localhost:5173,http://localhost:3029"
CORS_ORIGIN="http://localhost:3029"

ML_SERVICE_URL="http://localhost:5000"

# Bootstrap director (una vez: npm run db:bootstrap)
ADMIN_EMAIL="director@blenkir.edu.pe"
ADMIN_PASSWORD=""

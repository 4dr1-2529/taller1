# =============================================================================
# Backend — Railway producción (copiar a backend/.env local; NO subir .env)
# =============================================================================

# MySQL local (XAMPP)
# DATABASE_URL="mysql://root@localhost:3306/tesis_dashboard"

# MySQL Railway — TCP proxy externo o variable ${{MySQL.MYSQL_URL}}
# DATABASE_URL="mysql://USER:PASSWORD@acela.proxy.rlwy.net:34678/railway"

DATABASE_URL="mysql://root@localhost:3306/tesis_dashboard"

JWT_SECRET="cambiar-por-clave-segura-minimo-32-caracteres"
JWT_EXPIRES_IN="8h"

# Railway inyecta PORT; no fijar en producción salvo prueba local
PORT=4000
HOST=0.0.0.0
NODE_ENV=production

# Producción + desarrollo local
CORS_ORIGIN="https://taller1-frontend.vercel.app,http://localhost:3000,http://localhost:5173,http://localhost:3029"

ML_SERVICE_URL="http://localhost:5000"

ADMIN_EMAIL="director@blenkir.edu.pe"
ADMIN_PASSWORD=""

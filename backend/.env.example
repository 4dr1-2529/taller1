# =============================================================================
# Backend — variables de entorno (copiar a .env en local, NO subir .env a Git)
# Producción: configurar en Railway → Variables
# =============================================================================

# MySQL — local (XAMPP)
# DATABASE_URL="mysql://root@localhost:3306/tesis_dashboard"

# MySQL — Railway (usar la URL que provee el plugin MySQL)
# DATABASE_URL="mysql://USER:PASSWORD@HOST:PORT/railway?sslaccept=strict"

DATABASE_URL="mysql://root@localhost:3306/tesis_dashboard"

# JWT (mínimo 32 caracteres en producción)
JWT_SECRET="cambiar-por-clave-segura-minimo-32-caracteres"
JWT_EXPIRES_IN="8h"

# Servidor API (Railway inyecta PORT automáticamente)
PORT=4000
HOST=0.0.0.0
NODE_ENV=development

# CORS — URL del frontend (Vercel). Varios orígenes separados por coma:
# CORS_ORIGIN="https://tu-app.vercel.app,https://tu-app-git-main.vercel.app"
CORS_ORIGIN="http://localhost:3029"

# Servicio ML (opcional; desactivar features ML si no está desplegado)
ML_SERVICE_URL="http://localhost:5000"

# Primer director (solo local / una vez: npm run db:bootstrap)
ADMIN_EMAIL="director@blenkir.edu.pe"
ADMIN_PASSWORD=""

# Seed demo (solo desarrollo: npm run db:seed:demo)
# No definir contraseñas reales aquí en producción.

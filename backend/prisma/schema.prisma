generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

enum UserRole {
  admin
  docente
  tutor
  psicologo
  estudiante
}

enum StudentStatus {
  activo
  en_riesgo
  retirado
}

enum RiskLevel {
  bajo
  medio
  alto
}

enum AlertStatus {
  abierta
  en_seguimiento
  resuelta
}

enum NotificationType {
  alerta
  prediccion
  sistema
  reporte
}

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  passwordHash  String
  nombres       String
  apellidos     String
  role          UserRole  @default(estudiante)
  activo        Boolean   @default(true)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  sessions      Session[]
  notifications Notification[]
  @@index([role])
}

model Session {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash String
  ipAddress String?
  userAgent String?
  expiresAt DateTime
  createdAt DateTime @default(now())
  @@index([userId])
}

model Teacher {
  id            String   @id @default(cuid())
  codigo        String   @unique
  nombres       String
  apellidos     String
  especialidad  String
  correo        String
  telefono      String?
  activo        Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  courses       Course[]
  auditLogs     AuditLog[]
}

model Course {
  id          String       @id @default(cuid())
  codigo      String       @unique
  nombre      String
  nivel       String
  profesorId  String
  profesor    Teacher      @relation(fields: [profesorId], references: [id])
  activo      Boolean      @default(true)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  enrollments Enrollment[]
  @@index([profesorId])
}

model Student {
  id              String              @id @default(cuid())
  codigo          String              @unique
  nombres         String
  apellidos       String
  nivel           String
  correo          String
  telefono        String?
  estado          StudentStatus       @default(activo)
  promedioGeneral Float               @default(12)
  asistenciaGeneral Float             @default(80)
  lmsEngagement   String              @default("medio")
  activo          Boolean             @default(true)
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt
  enrollments     Enrollment[]
  academicHistory AcademicHistory[]
  lmsActivities   LmsActivity[]
  attendances     Attendance[]
  predictions     Prediction[]
  alerts          Alert[]
  riskRecords     StudentRisk[]
  recommendations AiRecommendation[]
  psychFollowUps  PsychologicalFollowUp[]
  auditLogs       AuditLog[]
  @@index([estado])
}

model Enrollment {
  id            String   @id @default(cuid())
  studentId     String
  courseId      String
  student       Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
  course        Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  promedio      Float
  asistenciaPct Float
  periodo       String   @default("2026-I")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  @@unique([studentId, courseId, periodo])
  @@index([studentId])
  @@index([courseId])
}

model AcademicHistory {
  id          String   @id @default(cuid())
  studentId   String
  student     Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
  periodo     String
  promedio    Float
  asistencia  Float
  observacion String?
  createdAt   DateTime @default(now())
  @@index([studentId, periodo])
}

model LmsActivity {
  id                  String   @id @default(cuid())
  studentId           String
  student             Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
  semana              String
  actividadPct        Float
  minutos             Int
  tareasEntregadas    Int
  tareasTotales       Int
  horasPlataforma     Float
  createdAt           DateTime @default(now())
  @@index([studentId, semana])
}

model Attendance {
  id         String   @id @default(cuid())
  studentId  String
  student    Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
  fecha      DateTime
  presente   Boolean
  justificado Boolean @default(false)
  createdAt  DateTime @default(now())
  @@index([studentId, fecha])
}

model Prediction {
  id              String    @id @default(cuid())
  studentId       String
  student         Student   @relation(fields: [studentId], references: [id], onDelete: Cascade)
  score           Float
  level           RiskLevel
  probability     Float?
  modelVersion    String
  modelName       String
  factorsJson     String
  metaJson        String?
  createdAt       DateTime  @default(now())
  @@index([studentId, createdAt])
  @@index([level])
}

model StudentRisk {
  id          String    @id @default(cuid())
  studentId   String
  student     Student   @relation(fields: [studentId], references: [id], onDelete: Cascade)
  score       Float
  level       RiskLevel
  periodo     String
  createdAt   DateTime  @default(now())
  @@index([studentId, periodo])
}

model Alert {
  id          String      @id @default(cuid())
  studentId   String
  student     Student     @relation(fields: [studentId], references: [id], onDelete: Cascade)
  titulo      String
  descripcion String
  factorKey   String?
  level       RiskLevel
  status      AlertStatus @default(abierta)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  @@index([status, level])
}

model AiRecommendation {
  id          String   @id @default(cuid())
  studentId   String
  student     Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
  factorKey   String
  titulo      String
  detalle     String
  aplicada    Boolean  @default(false)
  createdAt   DateTime @default(now())
  @@index([studentId])
}

model PsychologicalFollowUp {
  id          String   @id @default(cuid())
  studentId   String
  student     Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
  fecha       DateTime
  resumen     String
  acciones    String?
  profesional String?
  createdAt   DateTime @default(now())
  @@index([studentId])
}

model Notification {
  id        String           @id @default(cuid())
  userId    String
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  tipo      NotificationType
  titulo    String
  mensaje   String
  leida     Boolean          @default(false)
  createdAt DateTime         @default(now())
  @@index([userId, leida])
}

model Report {
  id          String   @id @default(cuid())
  titulo      String
  tipo        String
  generadoPor String?
  archivoPath String?
  metaJson    String?
  createdAt   DateTime @default(now())
}

model DashboardSnapshot {
  id              String   @id @default(cuid())
  periodo         String   @unique
  riesgoGlobal    Float
  totalEstudiantes Int
  alertasAbiertas Int
  metaJson        String?
  createdAt       DateTime @default(now())
}

model AuditLog {
  id         String   @id @default(cuid())
  entidad    String
  entidadId  String?
  accion     String
  usuarioId  String?
  detalle    String?
  ipAddress  String?
  createdAt  DateTime @default(now())
  studentId  String?
  student    Student? @relation(fields: [studentId], references: [id])
  teacherId  String?
  teacher    Teacher? @relation(fields: [teacherId], references: [id])
  @@index([entidad, createdAt])
}

model ChatMessage {
  id         String   @id @default(cuid())
  roomId     String
  senderId   String
  senderName String
  senderRole UserRole
  contenido  String
  createdAt  DateTime @default(now())
  @@index([roomId, createdAt])
}

{
  "name": "backend",
  "version": "2.0.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "start:prod": "node scripts/railway-start.mjs",
    "postinstall": "prisma generate",
    "prisma:generate": "prisma generate",
    "prisma:migrate:deploy": "prisma migrate deploy",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:migrate:deploy": "prisma migrate deploy",
    "db:migrate:resolve-rolled-back": "prisma migrate resolve --rolled-back 20250609120000_init",
    "db:migrate:regenerate-init": "node scripts/regenerate-init-migration.mjs",
    "db:railway:fix-p3009": "node scripts/railway-fix-p3009.mjs",
    "db:push": "prisma db push",
    "db:seed": "tsx prisma/seed.ts",
    "db:seed:prod": "prisma db seed",
    "db:seed:demo": "tsx prisma/seed-demo.ts",
    "db:reset:academic": "node scripts/reset-academic-data.mjs",
    "db:reset:full": "node scripts/reset-full-demo.mjs && npm run db:seed && npm run db:seed:demo && node scripts/validate-demo-data.mjs",
    "db:reseed": "npm run db:reset:full",
    "db:demo-bcrypt": "node scripts/print-demo-bcrypt.mjs",
    "db:update-passwords": "node scripts/update-all-passwords.mjs",
    "db:legacy-users": "tsx scripts/upsert-legacy-users.ts",
    "test": "node --test tests/*.test.mjs && tsx --test tests/schemas.test.ts tests/teacher-scope.test.ts tests/validation-fields.test.ts tests/estudiante-scope.test.ts",
    "db:bootstrap": "tsx prisma/bootstrap-admin.ts",
    "db:studio": "prisma studio",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "@prisma/client": "^6.3.1",
    "@tesis/shared": "*",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "express-rate-limit": "^7.5.0",
    "helmet": "^8.0.0",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.0",
    "prisma": "^6.3.1",
    "typescript": "^5",
    "xss": "^1.0.15",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/morgan": "^1.9.9",
    "@types/node": "^20",
    "tsx": "^4.19.2"
  }
}
